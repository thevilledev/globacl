{
  "name": "@globacl/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../docs/openapi.yaml -o src/generated/schema.d.ts",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json && mkdir -p dist/generated dist/global-ui && cp src/generated/schema.d.ts dist/generated/schema.d.ts && cp src/global-ui/index.html src/global-ui/styles.css src/global-ui/server.mjs dist/global-ui/",
    "test": "pnpm run build && node --test tests/*.test.mjs",
    "global-ui": "pnpm run build && node dist/global-ui/server.mjs"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "typescript": "6.0.3"
  }
}
